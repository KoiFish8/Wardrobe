{
  "version": "1.0",
  "scope": "young contemporary menswear-leaning",
  "weight_scale": { "S": 2, "W": 1, "none": 0 },
  "notes": "Research-grounded, self-corrected. tag_style_weights and tag_tag_compatibility list non-zero edges only.",
  "styles": {
    "minimal":     { "name": "Clean Minimal",      "formality": "smart-casual" },
    "street":      { "name": "Streetwear",         "formality": "casual" },
    "oldmoney":    { "name": "Old Money / Preppy",  "formality": "smart-formal" },
    "smartcasual": { "name": "Smart Casual",        "formality": "smart-casual" },
    "athleisure":  { "name": "Athleisure",          "formality": "casual" },
    "grunge":      { "name": "Grunge / Edgy",       "formality": "casual" },
    "y2kskate":    { "name": "Y2K / Skate",         "formality": "casual" },
    "workwear":    { "name": "Workwear / Rugged",   "formality": "casual" }
  },
  "tag_style_weights": {
    "oversized":           { "street": 2, "y2kskate": 2, "minimal": 1, "athleisure": 1, "grunge": 1, "workwear": 1 },
    "slim-fit":            { "oldmoney": 2, "smartcasual": 2, "minimal": 1, "street": 1, "athleisure": 1, "grunge": 1 },
    "baggy":               { "street": 2, "y2kskate": 2, "athleisure": 1, "grunge": 1, "workwear": 1 },
    "tailored":            { "oldmoney": 2, "smartcasual": 2, "minimal": 1 },
    "wide-leg":            { "street": 2, "y2kskate": 2, "minimal": 1, "grunge": 1, "workwear": 1 },
    "neutral-tones":       { "minimal": 2, "oldmoney": 2, "smartcasual": 2, "street": 1, "athleisure": 1, "grunge": 1, "y2kskate": 1, "workwear": 1 },
    "earth-tones":         { "street": 2, "workwear": 2, "minimal": 1, "oldmoney": 1, "smartcasual": 1, "grunge": 1 },
    "all-black":           { "grunge": 2, "minimal": 1, "street": 1, "smartcasual": 1, "athleisure": 1 },
    "washed-faded":        { "street": 2, "grunge": 2, "y2kskate": 2, "workwear": 1 },
    "bright-bold":         { "street": 1, "athleisure": 1, "y2kskate": 1 },
    "monochrome":          { "minimal": 2, "street": 1, "oldmoney": 1, "smartcasual": 1, "grunge": 1 },
    "raw-denim":           { "workwear": 2, "minimal": 1, "street": 1, "smartcasual": 1, "grunge": 1, "y2kskate": 1 },
    "leather":             { "street": 2, "grunge": 2, "oldmoney": 1, "smartcasual": 1, "y2kskate": 1, "workwear": 1 },
    "chunky-knit":         { "minimal": 2, "oldmoney": 2, "street": 1, "smartcasual": 1, "grunge": 1, "workwear": 1 },
    "technical-synthetic": { "athleisure": 2, "street": 1, "y2kskate": 1 },
    "suede":               { "oldmoney": 2, "minimal": 1, "smartcasual": 1, "workwear": 1 },
    "solid":               { "minimal": 2, "oldmoney": 2, "smartcasual": 2, "street": 1, "athleisure": 1, "grunge": 1, "y2kskate": 1, "workwear": 1 },
    "graphic-print":       { "street": 2, "y2kskate": 2, "athleisure": 1, "grunge": 1 },
    "plaid":               { "grunge": 2, "oldmoney": 1, "smartcasual": 1, "y2kskate": 1, "workwear": 1 },
    "chunky-sole-sneaker": { "street": 2, "minimal": 1, "athleisure": 1, "y2kskate": 1 },
    "performance-sneaker": { "athleisure": 2, "street": 1 },
    "boots":               { "grunge": 2, "workwear": 2, "street": 1, "oldmoney": 1, "smartcasual": 1 },
    "loafers":             { "oldmoney": 2, "smartcasual": 2, "minimal": 1 },
    "skate-shoe":          { "y2kskate": 2, "street": 1, "grunge": 1 },
    "minimal-branding":    { "minimal": 2, "oldmoney": 2, "smartcasual": 2, "street": 1, "grunge": 1, "workwear": 1 },
    "big-logo":            { "street": 2, "athleisure": 1, "y2kskate": 1 },
    "distressed":          { "grunge": 2, "y2kskate": 2, "street": 1, "workwear": 1 },
    "utility-pockets":     { "workwear": 2, "street": 1, "athleisure": 1, "y2kskate": 1 },
    "athletic-stripe":     { "athleisure": 2, "street": 1, "y2kskate": 1 },
    "heritage-detail":     { "oldmoney": 2, "workwear": 2, "minimal": 1, "smartcasual": 1 }
  },
  "tag_tag_compatibility": {
    "_comment": "Phase-2 layer: how well two tags pair WITHIN one outfit (not how similar they are). Non-zero edges only.",
    "oversized":      { "slim-fit": 2, "wide-leg": 2, "baggy": 1 },
    "slim-fit":       { "baggy": 2, "oversized": 2 },
    "leather":        { "chunky-knit": 2, "all-black": 2, "tailored": 1, "graphic-print": 1 },
    "chunky-knit":    { "tailored": 2, "wide-leg": 1, "leather": 2 },
    "tailored":       { "loafers": 2, "chunky-knit": 2, "leather": 1 },
    "graphic-print":  { "solid": 2 },
    "neutral-tones":  { "earth-tones": 2, "all-black": 1 },
    "bright-bold":    { "neutral-tones": 1, "all-black": 1 },
    "wide-leg":       { "boots": 2, "chunky-sole-sneaker": 2, "oversized": 2 },
    "baggy":          { "skate-shoe": 2, "chunky-sole-sneaker": 1 },
    "boots":          { "plaid": 1, "raw-denim": 2 },
    "loafers":        { "tailored": 2, "neutral-tones": 1 }
  },
  "incompatible_pairs": {
    "_comment": "Hard clashes — should suppress an outfit even if both tags individually fit the target style.",
    "tailored":            { "athletic-stripe": true, "technical-synthetic": true, "distressed": true },
    "performance-sneaker": { "tailored": true, "loafers": true },
    "graphic-print":       { "graphic-print": true },
    "big-logo":            { "heritage-detail": true }
  },
  "tag_style_anti_affinity": {
    "_comment": "Negative edges (added after validation): a tag that actively pushes an outfit AWAY from a style. Solves the false-positive where neutral/knit items alone scored old-money as high as minimal. Values are penalties subtracted from the style score.",
    "wide-leg":            { "oldmoney": -1, "smartcasual": -1 },
    "baggy":               { "oldmoney": -2, "smartcasual": -1 },
    "skate-shoe":          { "oldmoney": -2, "smartcasual": -1 },
    "chunky-sole-sneaker": { "oldmoney": -2 },
    "performance-sneaker": { "oldmoney": -2 },
    "technical-synthetic": { "oldmoney": -2, "minimal": -1 },
    "distressed":          { "oldmoney": -2, "smartcasual": -2, "minimal": -1 },
    "big-logo":            { "oldmoney": -2, "minimal": -2, "smartcasual": -1 },
    "athletic-stripe":     { "oldmoney": -2, "smartcasual": -1, "minimal": -1 },
    "washed-faded":        { "oldmoney": -1 },
    "bright-bold":         { "oldmoney": -1, "minimal": -1 }
  }
}
